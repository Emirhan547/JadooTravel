@using JadooTravel.Dto.Dtos.UserDtos
@model UpdateProfileDto

@{
    ViewData["Title"] = "Profili Düzenle";
    Layout = "~/Views/Shared/_UILayout.cshtml";
}

<section class="pt-9 pb-9">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card shadow-lg border-0" style="border-radius: 20px;">
                    <div class="card-header bg-primary text-white" style="border-radius: 20px 20px 0 0;">
                        <h3 class="mb-0">
                            <i class="fas fa-user-edit me-2"></i>Profili Düzenle
                        </h3>
                    </div>

                    <div class="card-body p-5">
                        <form method="post" asp-action="Edit">
                            <input type="hidden" asp-for="Id" />

                            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                            <!-- Ad Soyad -->
                            <div class="mb-3">
                                <label asp-for="FullName" class="form-label fw-medium">
                                    <i class="fas fa-user me-2"></i>Ad Soyad
                                </label>
                                <input asp-for="FullName"
                                       class="form-control form-control-lg"
                                       placeholder="Ad Soyad" />
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>

                            <!-- Email -->
                            <div class="mb-3">
                                <label asp-for="Email" class="form-label fw-medium">
                                    <i class="fas fa-envelope me-2"></i>Email
                                </label>
                                <input asp-for="Email"
                                       type="email"
                                       class="form-control form-control-lg"
                                       placeholder="Email" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <!-- Telefon -->
                            <div class="mb-3">
                                <label asp-for="PhoneNumber" class="form-label fw-medium">
                                    <i class="fas fa-phone me-2"></i>Telefon
                                </label>
                                <input asp-for="PhoneNumber"
                                       type="tel"
                                       class="form-control form-control-lg"
                                       placeholder="+90 (500) 000 00 00" />
                                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                            </div>

                            <!-- Adres -->
                            <div class="mb-3">
                                <label asp-for="Address" class="form-label fw-medium">
                                    <i class="fas fa-map-pin me-2"></i>Adres
                                </label>
                                <input asp-for="Address"
                                       class="form-control form-control-lg"
                                       placeholder="Adres giriniz" />
                                <span asp-validation-for="Address" class="text-danger small"></span>
                            </div>

                            <!-- Şehir -->
                            <div class="mb-3">
                                <label asp-for="City" class="form-label fw-medium">
                                    <i class="fas fa-city me-2"></i>Şehir
                                </label>
                                <input asp-for="City"
                                       class="form-control form-control-lg"
                                       placeholder="Şehir" />
                                <span asp-validation-for="City" class="text-danger small"></span>
                            </div>

                            <!-- Ülke -->
                            <div class="mb-3">
                                <label asp-for="Country" class="form-label fw-medium">
                                    <i class="fas fa-flag me-2"></i>Ülke
                                </label>
                                <input asp-for="Country"
                                       class="form-control form-control-lg"
                                       placeholder="Ülke" />
                                <span asp-validation-for="Country" class="text-danger small"></span>
                            </div>

                            <!-- Profile Image URL -->
                            <div class="mb-4">
                                <label asp-for="ProfileImageUrl" class="form-label fw-medium">
                                    <i class="fas fa-image me-2"></i>Profil Fotoğrafı URL
                                </label>
                                <input asp-for="ProfileImageUrl"
                                       class="form-control form-control-lg"
                                       placeholder="https://example.com/photo.jpg" />
                                <small class="text-muted d-block mt-2">
                                    Profil fotoğrafınızın URL'sini giriniz
                                </small>
                                <span asp-validation-for="ProfileImageUrl" class="text-danger small"></span>
                            </div>

                            <!-- Buttons -->
                            <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                                <a href="/Profile/Index" class="btn btn-secondary btn-lg">
                                    <i class="fas fa-times me-2"></i>İptal
                                </a>
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="fas fa-save me-2"></i>Kaydet
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            @if (TempData["success"] != null)
            {
                    <text>
                        Swal.fire({
                            icon: 'success',
                            title: 'Başarılı!',
                            text: '@TempData["success"]'
                        });
                    </text>
            }
        });
    </script>
}
