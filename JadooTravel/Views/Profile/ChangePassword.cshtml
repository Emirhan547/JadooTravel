@using JadooTravel.Dto.Dtos.UserDtos
@model ChangePasswordDto

@{
    ViewData["Title"] = "Şifre Değiştir";
    Layout = "~/Views/Shared/_UILayout.cshtml";
    var successMessage = TempData["success"]?.ToString();
}

<section class="pt-9 pb-9">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="card shadow-lg border-0" style="border-radius: 20px;">
                    <div class="card-header bg-warning text-white" style="border-radius: 20px 20px 0 0;">
                        <h3 class="mb-0">
                            <i class="fas fa-key me-2"></i>Şifre Değiştir
                        </h3>
                    </div>

                    <div class="card-body p-5">
                        <form method="post" asp-action="ChangePassword">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                            <div class="mb-3">
                                <label asp-for="CurrentPassword" class="form-label fw-medium">
                                    <i class="fas fa-lock me-2"></i>Mevcut Şifre
                                </label>
                                <input asp-for="CurrentPassword"
                                       type="password"
                                       class="form-control form-control-lg"
                                       placeholder="Mevcut şifreniz" />
                                <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="NewPassword" class="form-label fw-medium">
                                    <i class="fas fa-lock-open me-2"></i>Yeni Şifre
                                </label>
                                <input asp-for="NewPassword"
                                       type="password"
                                       class="form-control form-control-lg"
                                       placeholder="Yeni şifre" />
                                <small class="text-muted d-block mt-2">
                                    Şifreniz en az 6 karakter olmalıdır
                                </small>
                                <span asp-validation-for="NewPassword" class="text-danger small"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="ConfirmPassword" class="form-label fw-medium">
                                    <i class="fas fa-check-circle me-2"></i>Yeni Şifre (Tekrar)
                                </label>
                                <input asp-for="ConfirmPassword"
                                       type="password"
                                       class="form-control form-control-lg"
                                       placeholder="Yeni şifre (tekrar)" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                            </div>

                            <div class="alert alert-info" role="alert">
                                <i class="fas fa-info-circle me-2"></i>
                                <strong>Güvenlik:</strong> Şifrenizi kimseyle paylaşmayın. Güçlü bir şifre kullanmanız önerilir.
                            </div>

                            <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                                <a href="/Profile/Index" class="btn btn-secondary btn-lg">
                                    <i class="fas fa-times me-2"></i>İptal
                                </a>
                                <button type="submit" class="btn btn-warning btn-lg">
                                    <i class="fas fa-save me-2"></i>Şifreyi Değiştir
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="card shadow-lg border-0 mt-4" style="border-radius: 20px;">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3">
                            <i class="fas fa-shield-alt me-2"></i>Güvenlik İpuçları
                        </h5>
                        <ul class="list-unstyled">
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Büyük ve küçük harf kullanınız</li>
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Rakam ve özel karakter ekleyiniz</li>
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i>En az 8 karakter yapınız</li>
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Kişisel bilgi kullanmayınız</li>
                            <li><i class="fas fa-check text-success me-2"></i>Düzenli olarak değiştirin</li>
                        </ul>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {

            var successMessage = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(successMessage));

            if (successMessage) {
                Swal.fire({
                    icon: 'success',
                    title: 'Başarılı!',
                    text: successMessage
                });
            }
        });
    </script>
}