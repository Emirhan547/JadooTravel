@using JadooTravel.Dto.Dtos.UserDtos
@model List<UserFavoriteDto>

@{
    ViewData["Title"] = "Favorilerim";
    Layout = "~/Views/Shared/_UILayout.cshtml";
}

<section class="pt-9 pb-9">
    <div class="container">
        <div class="row mb-4 align-items-center">
            <div class="col-12">
                <h2 class="fw-bold mb-1">
                    <i class="fas fa-heart text-danger me-2"></i>Favori Destinasyonlarım
                </h2>
                <p class="text-muted">Toplam @Model.Count favori</p>
            </div>
        </div>

        @if (Model.Count > 0)
        {
            <div class="row">
                @foreach (var item in Model)
                {
                    <div class="col-md-6 col-lg-4 mb-4">
                        <div class="card shadow-lg border-0 h-100" style="border-radius: 15px; overflow: hidden;">
                            <!-- Image -->
                            <div class="position-relative" style="height: 250px; overflow: hidden;">
                                <img src="@item.ImageUrl"
                                     alt="@item.CityCountry"
                                     class="w-100 h-100"
                                     style="object-fit: cover;">

                                <!-- Remove Favorite Button -->
                                <button class="btn btn-danger btn-circle position-absolute top-2 end-2 remove-favorite-btn"
                                        data-favorite-id="@item.Id"
                                        style="width: 45px; height: 45px; border-radius: 50%; border: none;">
                                    <i class="fas fa-heart"></i>
                                </button>

                                <!-- Price Badge -->
                                <div class="position-absolute bottom-0 start-0 bg-dark text-white px-3 py-2"
                                     style="border-radius: 0 15px 0 0;">
                                    <h5 class="mb-0">@item.Price.ToString("C")</h5>
                                </div>
                            </div>

                            <!-- Content -->
                            <div class="card-body p-4">
                                <h5 class="card-title fw-bold mb-3">@item.CityCountry</h5>

                                <div class="d-flex justify-content-between align-items-center mt-4">
                                    <small class="text-muted">
                                        <i class="fas fa-calendar me-2"></i>
                                        @item.CreatedDate.ToString("dd.MM.yyyy")
                                    </small>
                                </div>

                                <!-- Action Buttons -->
                                <div class="d-grid gap-2 mt-3">
                                    <a href="#" class="btn btn-primary btn-sm">
                                        <i class="fas fa-book me-2"></i>Rezervasyon Yap
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="alert alert-info text-center py-5" role="alert">
                <div class="mb-3">
                    <i class="fas fa-heart-broken" style="font-size: 3rem; color: #6c757d;"></i>
                </div>
                <h4 class="fw-bold">Henüz Favori Destinasyon Eklemediniz</h4>
                <p class="text-muted mb-3">Seyahatlerinize ilham almak için destinasyonları favorilerinize ekleyin.</p>
                <a href="/Default/Index#destination" class="btn btn-primary">
                    <i class="fas fa-map-marked-alt me-2"></i>Destinasyonları Keşfet
                </a>
            </div>
        }

        <!-- Back Button -->
        <div class="row mt-4">
            <div class="col-12">
                <a href="/Profile/Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Profile Dön
                </a>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Remove Favorite
        document.querySelectorAll('.remove-favorite-btn').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                const favoriteId = this.getAttribute('data-favorite-id');

                Swal.fire({
                    title: 'Emin misiniz?',
                    text: 'Bu destinasyonu favorilerden kaldırmak istediğinize emin misiniz?',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#dc3545',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Evet, Kaldır!',
                    cancelButtonText: 'İptal'
                }).then((result) => {
                    if (result.isConfirmed) {
                        fetch('/Profile/RemoveFavorite', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                            },
                            body: JSON.stringify({ favoriteId: favoriteId })
                        })
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Başarılı!',
                                    text: data.message,
                                    timer: 1500,
                                    didClose: () => {
                                        location.reload();
                                    }
                                });
                            } else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Hata!',
                                    text: data.message
                                });
                            }
                        });
                    }
                });
            });
        });
    </script>
}
