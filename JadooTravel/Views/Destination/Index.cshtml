@model List<JadooTravel.Dto.Dtos.DestinationDtos.ResultDestinationDto>
@{
    Layout = "~/Views/Shared/_UILayout.cshtml";
    ViewData["Title"] = "Tüm Turlar";
}

<section class="pt-8 pb-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0">Tüm Turlar</h2>
            <a href="/Default/Index#destination" class="btn btn-outline-secondary">Anasayfaya Dön</a>
        </div>
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm">
                        <img src="@item.ImageUrl" class="card-img-top" alt="@item.CityCountry" style="height:220px;object-fit:cover;" />
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@item.CityCountry</h5>
                            <p class="text-muted small">@item.DayNight • Kişi: @item.Capacity</p>
                            <p class="card-text">@item.Description</p>
                            <div class="mt-auto d-flex justify-content-between align-items-center">
                                <span class="fw-bold">@item.Price ₺</span>
                                <a href="/Destination/Detail/@item.Id" class="btn btn-primary btn-sm">Detaya Git</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>