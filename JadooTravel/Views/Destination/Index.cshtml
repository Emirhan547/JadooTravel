@model List<JadooTravel.Dto.Dtos.DestinationDtos.ResultDestinationDto>
@{
    Layout = "~/Views/Shared/_UILayout.cshtml";
    ViewData["Title"] = "Tüm Turlar";
}

<style>
    /* === IMAGE STANDARD === */
    .tour-image-wrapper {
        width: 100%;
        aspect-ratio: 4 / 3;
        overflow: hidden;
        border-radius: 14px 14px 0 0;
    }

        .tour-image-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

    /* === CARD STYLE === */
    .destination-card {
        border: none;
        border-radius: 14px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, .08);
        transition: all .3s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
        background-color: #fff;
    }

        .destination-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 18px 40px rgba(0, 0, 0, .15);
        }

        .destination-card .card-body {
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }

    /* === CLEAN DESCRIPTION LIMIT === */
    .description-clamp {
        display: -webkit-box;
        -webkit-line-clamp: 3; /* 3 satır */
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
        font-size: 0.9rem;
        line-height: 1.6;
        color: #6c757d;
        margin-bottom: 15px;
    }

    .price-section {
        margin-top: auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
</style>

<section class="pt-8 pb-5">
    <div class="container">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0">Tüm Turlar</h2>
            <a href="/Default/Index#destination" class="btn btn-outline-secondary">
                Anasayfaya Dön
            </a>
        </div>

        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card destination-card">

                        <!-- IMAGE -->
                        <div class="tour-image-wrapper">
                            <img src="@item.ImageUrl" alt="@item.CityCountry" />
                        </div>

                        <!-- BODY -->
                        <div class="card-body">

                            <h5 class="mt-2 fw-semibold">
                                @item.CityCountry
                            </h5>

                            <small class="text-muted mb-2 d-block">
                                @item.DayNight • Kişi: @item.Capacity
                            </small>

                            <p class="description-clamp">
                                @item.Description
                            </p>

                            <div class="price-section">
                                <span class="fw-bold">
                                    @item.Price.ToString("N2") ₺
                                </span>

                                <a href="/Destination/Detail/@item.Id"
                                   class="btn btn-warning btn-sm">
                                    Detaya Git
                                </a>
                            </div>

                        </div>

                    </div>
                </div>
            }
        </div>

    </div>
</section>