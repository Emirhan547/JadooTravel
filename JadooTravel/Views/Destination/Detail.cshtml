@model JadooTravel.UI.Models.DestinationDetailViewModel
@{
    Layout = "~/Views/Shared/_UILayout.cshtml";
    ViewData["Title"] = Model.Destination.CityCountry;
}

<style>
    /* === HERO === */
    .detail-hero {
        max-width: 900px;
        margin: 0 auto 50px auto;
        border-radius: 18px;
        overflow: hidden;
    }

        .detail-hero img {
            width: 100%;
            aspect-ratio: 16 / 8;
            object-fit: cover;
            display: block;
        }

    /* === HEADER === */
    .detail-header {
        max-width: 900px;
        margin: 0 auto 30px auto;
    }

        .detail-header h1 {
            font-weight: 600;
            margin-bottom: 10px;
            position: relative;
            padding-bottom: 10px;
        }

            .detail-header h1::after {
                content: "";
                width: 50px;
                height: 3px;
                background: #ffc107;
                position: absolute;
                bottom: 0;
                left: 0;
                border-radius: 2px;
            }

    .detail-meta {
        color: #6c757d;
        font-size: 0.95rem;
        margin-top: 12px;
        margin-bottom: 8px;
    }

    .detail-price {
        font-size: 1.5rem;
        font-weight: 600;
        color: #212529;
        margin-top: 5px;
    }

    /* === CONTENT === */
    .detail-content {
        max-width: 900px;
        margin: 0 auto 60px auto;
        line-height: 1.9;
        font-size: 1rem;
        color: #495057;
    }

    /* === REVIEWS === */
    .review-wrapper {
        max-width: 900px;
        margin: 0 auto;
    }

        .review-wrapper h4 {
            margin-bottom: 30px;
            font-weight: 600;
        }

    .review-item {
        padding: 20px;
        border-radius: 12px;
        background: #f8f9fa;
        margin-bottom: 15px;
    }

    .star-rating {
        color: #ffc107;
        font-size: 0.95rem;
    }

    .review-item strong {
        font-weight: 600;
    }

    /* Buton minimal */
    .btn-dark {
        background-color: #212529;
        border: none;
    }

        .btn-dark:hover {
            background-color: #000;
        }
</style>

<section class="pt-5 pb-5">
    <div class="container">

        <a href="/Destination/Index" class="btn btn-outline-secondary mb-4">
            ← Tüm Turlar
        </a>

        <!-- HERO -->
        <div class="detail-hero">
            <img src="@Model.Destination.ImageUrl"
                 alt="@Model.Destination.CityCountry" />
        </div>

        <!-- HEADER -->
        <div class="detail-header">
            <h1>@Model.Destination.CityCountry</h1>

            <div class="detail-meta">
                @Model.Destination.DayNight • Kişi kapasitesi: @Model.Destination.Capacity
            </div>

            <div class="detail-price">
                @Model.Destination.Price.ToString("N2") ₺
            </div>
        </div>

        <!-- DESCRIPTION -->
        <div class="detail-content">
            @Model.Destination.Description
        </div>

        <!-- REVIEWS -->
        <div class="review-wrapper">
            <h4>Yorumlar</h4>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <form method="post"
                      asp-controller="Review"
                      asp-action="UpsertInline"
                      class="mb-5"
                      id="reviewForm">

                    @Html.AntiForgeryToken()
                    <input type="hidden" name="destinationId" value="@Model.Destination.Id" />
                    <input type="hidden" name="reviewId" id="reviewId" />

                    <div class="row g-2">
                        <div class="col-md-2">
                            <input type="number" min="1" max="5"
                                   name="rating"
                                   class="form-control"
                                   placeholder="Puan (1-5)" required />
                        </div>
                        <div class="col-md-3">
                            <input type="number" min="1"
                                   name="visitedDays"
                                   class="form-control"
                                   placeholder="Kaç gün?" required />
                        </div>
                        <div class="col-md-7">
                            <input type="text"
                                   name="title"
                                   class="form-control"
                                   placeholder="Başlık" required />
                        </div>
                        <div class="col-12">
                            <textarea name="comment"
                                  class="form-control"
                                  rows="3"
                                  placeholder="Yorumunuz"
                                  required></textarea>
                        </div>
                    </div>

                    <div class="mt-3">
                        <button type="submit"
                                class="btn btn-dark"
                                id="reviewSubmitBtn">
                            Yorum Ekle
                        </button>
                    </div>
                </form>
            }
            else
            {
                <div class="alert alert-info">
                    Yorum yapmak için <a href="/Auth/Login">giriş yapın</a>.
                </div>
            }

            @if (Model.Reviews.Any())
            {
                @foreach (var review in Model.Reviews)
                {
                    <div class="review-item">
                        <strong>@review.UserName</strong>
                        <span class="text-muted ms-2">
                            @review.CreatedDate.ToLocalTime().ToString("dd.MM.yyyy")
                        </span>

                        <div class="star-rating mt-1">
                            @(new string('★', review.Rating) + new string('☆', 5 - review.Rating))
                        </div>

                        <h6 class="mt-2">@review.Title</h6>
                        <p class="mb-0">@review.Comment</p>
                    </div>
                }
            }
            else
            {
                <p class="text-muted">Henüz yorum yok.</p>
            }
        </div>

    </div>
</section>