@model List<ResultCategoryDto>


<section class="pt-5 pt-md-9" id="service">
    <div class="container position-relative">
       
        <div class="mb-7 text-center">
            <h5 class="text-secondary">Kategoriler</h5>
            <h3 class="fs-xl-10 fs-lg-8 fs-7 fw-bold font-cursive text-capitalize">
                En İyi Hizmetleri Sunuyoruz
            </h3>
        </div>
        <div class="row">
            @foreach (var item in Model.Where(x => x.Status).Take(4))
            {
                <div class="col-lg-3 col-sm-6 mb-6">
                    <div class="card service-card shadow-hover rounded-3 text-center align-items-center">
                        <div class="card-body p-xxl-5 p-4">
                            <i class="@item.IconUrl" style="font-size: 48px;"></i>
                            <h4 class="mb-3">@item.CategoryName</h4>
                            <p class="mb-0 fw-medium">@item.Description</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>