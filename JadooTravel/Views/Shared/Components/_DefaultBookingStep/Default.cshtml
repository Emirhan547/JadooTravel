@model List<ResultTripPlanDto>

@using JadooTravel.Dto.Dtos.DestinationDtos

@{
    var destinations = (ViewBag.Destinations as List<ResultDestinationDto>) ?? new List<ResultDestinationDto>();
}

<section id="booking">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <div class="mb-4 text-start">
                    <h5 class="text-secondary">Kolay ve Hızlı</h5>
                    <h3 class="fs-xl-10 fs-lg-8 fs-7 fw-bold font-cursive text-capitalize">
                        Bir Sonraki Seyahatinizi @Model.Count Kolay Adımda Planlayın
                    </h3>
                </div>

                @{
                    var colors = new[] { "primary", "danger", "info", "success" };
                }

                @for (int i = 0; i < Model.Take(4).Count(); i++)
                {
                    var item = Model[i];
                    <div class="d-flex align-items-start mb-5">
                        <div class="bg-@colors[i % colors.Length] me-sm-4 me-3 p-3" style="border-radius: 13px">
                            <i class="@item.IconUrl text-white" style="font-size: 20px;"></i>
                        </div>
                        <div class="flex-1">
                            <h5 class="text-secondary fw-bold fs-0">@item.Title</h5>
                            <p>@item.Description</p>
                        </div>
                    </div>
                }
            </div>

            <div class="col-lg-6 d-flex justify-content-center align-items-start">
                <div class="card shadow-lg border-info" style="width: 100%; max-width: 500px;">
                    <div class="card-header bg-info text-white text-center">
                        <h5 class="mb-0">Rezervasyon Formu</h5>
                    </div>
                    <div class="card-body">
  
                        <form method="post" asp-controller="Booking" asp-action="CreateBooking" id="bookingForm">
                            @Html.AntiForgeryToken()
                            <div class="mb-3">
                                <input type="text"
                                       name="FullName"
                                       class="form-control"
                                       placeholder="İsim Soyisim"
                                       required />
                            </div>

                            <div class="mb-3">
                                <input type="tel"
                                       name="Phone"
                                       class="form-control"
                                       placeholder="Telefon"
                                       required />
                            </div>

                            <div class="mb-3">
                                <input type="email"
                                       name="Email"
                                       class="form-control"
                                       placeholder="Email"
                                       required />
                            </div>

                            <div class="mb-3">
                                <select name="DestinationId" id="destinationSelect" class="form-select" required>
                                    <option value="">Tur Seçiniz</option>
                                    @foreach (var destination in destinations)
                                    {
                                        <option value="@destination.Id" data-price="@destination.Price">@destination.CityCountry (@destination.Price.ToString("C0"))</option>
                                    }
                                </select>
                            </div>

                            <div class="row g-2 mb-3">
                                <div class="col-md-6">
                                    <input type="date"
                                           name="StartDate"
                                           id="startDate"
                                           class="form-control"
                                           required />
                                </div>
                                <div class="col-md-6">
                                    <input type="date"
                                           name="EndDate"
                                           id="endDate"
                                           class="form-control"
                                           required />
                                </div>
                            </div>

                            <div class="mb-3">
                                <input type="number"
                                       name="PersonCount"
                                       id="personCount"
                                       class="form-control"
                                       placeholder="Kişi Sayısı"
                                       min="1"
                                       value="1"
                                       required />
                            </div>

                            <div class="mb-3">
                                <input type="number"
                                       name="TotalPrice"
                                       id="totalPrice"
                                       class="form-control"
                                       placeholder="Toplam Fiyat"
                                       min="0"
                                       step="0.01"
                                       readonly
                                       required />
                            </div>

                            <div class="mb-3">
                                <textarea rows="3"
                                          name="MessageBody"
                                          class="form-control"
                                          placeholder="Mesajınız"></textarea>
                            </div>

                            <div class="d-grid">
                                <button type="submit" class="btn btn-info">
                                    Rezervasyon Yap
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<script>
    (function () {
        const destinationSelect = document.getElementById('destinationSelect');
        const startDate = document.getElementById('startDate');
        const endDate = document.getElementById('endDate');
        const personCount = document.getElementById('personCount');
        const totalPrice = document.getElementById('totalPrice');

        if (!destinationSelect || !startDate || !endDate || !personCount || !totalPrice) return;

        const today = new Date().toISOString().split('T')[0];
        startDate.min = today;
        endDate.min = today;

        function calculateTotalPrice() {
            const selectedOption = destinationSelect.options[destinationSelect.selectedIndex];
            const pricePerPersonPerDay = Number(selectedOption?.dataset?.price || 0);
            const people = Number(personCount.value || 0);

            const start = startDate.value ? new Date(startDate.value) : null;
            const end = endDate.value ? new Date(endDate.value) : null;

            let dayCount = 0;
            if (start && end && end >= start) {
                const diffTime = end.getTime() - start.getTime();
                dayCount = Math.max(1, Math.ceil(diffTime / (1000 * 60 * 60 * 24)));
            }

            const total = pricePerPersonPerDay * people * dayCount;
            totalPrice.value = total > 0 ? total.toFixed(2) : '';
        }

        function onStartDateChange() {
            if (startDate.value) {
                endDate.min = startDate.value;
                if (endDate.value && endDate.value < startDate.value) {
                    endDate.value = startDate.value;
                }
            }
            calculateTotalPrice();
        }

        destinationSelect.addEventListener('change', calculateTotalPrice);
        startDate.addEventListener('change', onStartDateChange);
        endDate.addEventListener('change', calculateTotalPrice);
        personCount.addEventListener('input', calculateTotalPrice);
    })();
</script>