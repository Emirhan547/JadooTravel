@using JadooTravel.Dto.Dtos.PartnerDtos

@model List<ResultPartnerDto>
<div class="position-relative pt-9 pt-lg-8 pb-6 pb-lg-8">
    <div class="container">
        <div class="row row-cols-lg-5 row-cols-md-3 row-cols-2 flex-center">
           
            @if (Model != null && Model.Count > 0)
            {
                @foreach (var item in Model)
                {
                    <div class="col">
                        <div class="card shadow-hover mb-4" style="border-radius:10px;">
                            <div class="card-body text-center">
                                <img class="img-fluid" src="@item.ImageUrl" alt="@item.Name" />
                            </div>
                        </div>
                    </div>
               
                }
            }
            else
            {
                <div class="col"><div class="card shadow-hover mb-4" style="border-radius:10px;"><div class="card-body text-center"><img class="img-fluid" src="/public/assets/img/partner/1.png" alt="Partner 1" /></div></div></div>
                <div class="col"><div class="card shadow-hover mb-4" style="border-radius:10px;"><div class="card-body text-center"><img class="img-fluid" src="/public/assets/img/partner/2.png" alt="Partner 2" /></div></div></div>
                <div class="col"><div class="card shadow-hover mb-4" style="border-radius:10px;"><div class="card-body text-center"><img class="img-fluid" src="/public/assets/img/partner/3.png" alt="Partner 3" /></div></div></div>
                <div class="col"><div class="card shadow-hover mb-4" style="border-radius:10px;"><div class="card-body text-center"><img class="img-fluid" src="/public/assets/img/partner/4.png" alt="Partner 4" /></div></div></div>
                <div class="col"><div class="card shadow-hover mb-4" style="border-radius:10px;"><div class="card-body text-center"><img class="img-fluid" src="/public/assets/img/partner/5.png" alt="Partner 5" /></div></div></div>
            }
        </div>
    </div>
</div>
