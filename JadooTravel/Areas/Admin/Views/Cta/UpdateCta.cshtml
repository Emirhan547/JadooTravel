@using JadooTravel.Dto.Dtos.CtaDtos
@model UpdateCtaDto
@{
    ViewData["Title"] = "CTA Güncelle"; Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="card">
    <div class="card-header"><h3 class="card-title">CTA Güncelle</h3></div>
    <form method="post">
        <input type="hidden" asp-for="Id" /><div class="card-body">
            <div class="form-group"><label>Başlık</label><input asp-for="Title" class="form-control" /></div>
     
        </div><div class="card-footer"><button class="btn btn-warning">Güncelle</button><a href="/Admin/Cta/CtaList" class="btn btn-secondary ml-2">İptal</a></div>
    </form>
</div>