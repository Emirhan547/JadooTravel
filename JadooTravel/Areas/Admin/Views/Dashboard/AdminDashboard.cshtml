@using JadooTravel.Dto.Dtos.DashboardDtos
@using Microsoft.AspNetCore.Mvc.ViewFeatures
@model DashboardStatisticsDto

@inject IJsonHelper Json

@{
    ViewData["Title"] = "AdminDashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var statusRows = Model.BookingStatusData
        .Select(item => new
        {
            item.Status,
            item.Count,
            Rate = Model.FilteredBookings == 0 ? 0 : (double)item.Count / Model.FilteredBookings * 100
        })
        .OrderByDescending(x => x.Count)
        .ToList();
}

<style>
  
       
    .hero-card {
        border: 0;
      
        border-radius: 22px;
        background: radial-gradient(circle at 15% 20%, rgba(255, 255, 255, .2), transparent 45%),
                    linear-gradient(125deg, #0f172a 0%, #1e3a8a 45%, #0891b2 100%);
        color: #fff;
       
       
        box-shadow: 0 16px 40px rgba(15, 23, 42, 0.26);
    }

  
       
    .hero-chip {
        background: rgba(255, 255, 255, .16);
        border: 1px solid rgba(255, 255, 255, .22);
        border-radius: 999px;
        padding: .35rem .8rem;
        font-size: .8rem;
        letter-spacing: .2px;
    }

    .admin-dashboard-wrapper {
        padding-top: 15px; /* Navbar ile mesafe */
    }
    
    .stat-tile {
        border: 0;
        border-radius: 16px;
        box-shadow: 0 10px 24px rgba(15, 23, 42, .08);
        overflow: hidden;
    }

   
        
    .stat-tile .icon {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #fff;
    }

   
       
    .panel-card {
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        box-shadow: 0 8px 22px rgba(15, 23, 42, .05);
    }

  
       
    .panel-title {
        font-weight: 600;
        color: #0f172a;
    }

  
       
    .chart-wrapper {
        height: 310px;
    }

   
       
    .destination-thumb {
        width: 64px;
        height: 48px;
        border-radius: 10px;
        object-fit: cover;
    }

    .soft-table thead th {
        border: none;
        background: #f8fafc;
      
        color: #475569;
        font-weight: 600;
    }

    .soft-table td {
        border-color: #f1f5f9;
        vertical-align: middle;
    }

   

    .kpi-table td,
    .kpi-table th {
        padding: .8rem;
        vertical-align: middle;
    }


    .kpi-table tbody tr:hover {
        background: #f8fafc;
    }

 
            
                  
    canvas {
        image-rendering: -webkit-optimize-contrast;
    }
</style>

       
<div class="container-fluid admin-dashboard-wrapper">
    <div class="card hero-card mb-4">
        <div class="card-body d-flex flex-wrap justify-content-between align-items-end gap-3">
            <div>
               
                <small class="text-white-50 d-block mb-1">Jadoo Travel Yönetim Merkezi</small>
                <h3 class="mb-1">Admin Dashboard</h3>
                <p class="mb-2 text-white-50">Temaya uyumlu, okunabilir ve aksiyon odaklı kontrol paneli</p>
                <div class="d-flex flex-wrap gap-2">
                    <span class="hero-chip">Filtreli Rezervasyon: @Model.FilteredBookings</span>
                    <span class="hero-chip">Onay Oranı: %@Model.ApprovalRate.ToString("N1")</span>
                    <span class="hero-chip">Gelir: @Model.TotalRevenue.ToString("N0") ₺</span>
                </div>
            </div>
          

            <form method="get" asp-area="Admin" asp-controller="Dashboard" asp-action="AdminDashboard" class="d-flex flex-wrap align-items-end gap-2">
                <div>
                    <label class="form-label text-white mb-1">Başlangıç</label>
                    <input type="date" class="form-control" name="startDate" value="@Model.StartDate.ToString("yyyy-MM-dd")" />
                </div>
                <div>
                    <label class="form-label text-white mb-1">Bitiş</label>
                    <input type="date" class="form-control" name="endDate" value="@Model.EndDate.ToString("yyyy-MM-dd")" />
                </div>
                <button type="submit" class="btn btn-light text-dark">Filtrele</button>
            </form>
        </div>
    </div>
        
    <div class="row">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card stat-tile h-100">
                <div class="card-body">
                    
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted">Kategoriler</span>
                        <span class="icon" style="background:#2563eb"><i class="fa fa-tags"></i></span>
                    </div>
                    <h4 class="mb-0">@Model.TotalCategories</h4>
                    <small class="text-success">Aktif: @Model.ActiveCategories</small>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
           
              
            <div class="card stat-tile h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted">Destinasyonlar</span>
                        <span class="icon" style="background:#14b8a6"><i class="fa fa-map-marker"></i></span>
                    </div>
                    <h4 class="mb-0">@Model.TotalDestinations</h4>
                    <small class="text-muted">Sistemdeki toplam tur noktası</small>
                </div>
            </div>
        </div>

          
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card stat-tile h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted">Toplam Rezervasyon</span>
                        <span class="icon" style="background:#f59e0b"><i class="fa fa-ticket"></i></span>
                    </div>
                    <h4 class="mb-0">@Model.TotalBookings</h4>
                    <small class="text-muted">Filtre aralığı: @Model.FilteredBookings</small>
                </div>
            </div>
        </div>

               
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card stat-tile h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted">Yorumlar</span>
                        <span class="icon" style="background:#8b5cf6"><i class="fa fa-comments"></i></span>
                    </div>
                    <h4 class="mb-0">@Model.TotalTestimonials</h4>
                    <small class="text-muted">Müşteri geri bildirim adedi</small>
                </div>
            </div>
        </div>
    </div>

             
    <div class="row">
        <div class="col-lg-8 mb-4">
            <div class="card panel-card h-100">
                <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center">
                    <h6 class="panel-title mb-0">Rezervasyon Performans Özeti</h6>
                    <span class="badge bg-light text-dark">Son 30 gün yerine filtre tarihine göre</span>
                </div>
                <div class="card-body table-responsive">
                    <table class="table kpi-table mb-0">
                        <thead>
                            <tr>
                                <th>Durum</th>
                                <th class="text-center">Adet</th>
                                <th class="text-center">Oran</th>
                                <th>Dağılım</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in statusRows)
                            {
                                <tr>
                                    <td>@row.Status</td>
                                    <td class="text-center fw-semibold">@row.Count</td>
                                    <td class="text-center text-muted">%@row.Rate.ToString("N1")</td>
                                    <td>
                                        <div class="progress" style="height:7px;">
                                            <div class="progress-bar bg-info" role="progressbar" style="width:@Math.Min(100, row.Rate)%"></div>
                                        </div>
                                 
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <div class="mt-3 p-3 rounded-3 bg-light d-flex flex-wrap gap-3">
                        <div><small class="text-muted d-block">Ortalama Rezervasyon</small><strong>@Model.AverageBookingAmount.ToString("N0") ₺</strong></div>
                        <div><small class="text-muted d-block">Onay Dönüşüm</small><strong>%@Model.ApprovalRate.ToString("N1")</strong></div>
                        <div><small class="text-muted d-block">Toplam Gelir</small><strong>@Model.TotalRevenue.ToString("N0") ₺</strong></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4 mb-4">
            <div class="card panel-card h-100">
                <div class="card-header bg-white border-0">
                    <h6 class="panel-title mb-0">Rezervasyon Durum Dağılımı</h6>
                </div>
                <div class="card-body">
                    <div class="chart-wrapper" style="height:260px;">
                        <canvas id="statusDistributionChart"></canvas>
                    </div>
                    <div class="row text-center mt-2">
                        <div class="col-6 mb-2"><span class="badge bg-success w-100">Onaylı: @Model.ApprovedBookings</span></div>
                        <div class="col-6 mb-2"><span class="badge bg-warning text-dark w-100">Beklemede: @Model.PendingBookings</span></div>
                        <div class="col-6 mb-2"><span class="badge bg-danger w-100">Reddedildi: @Model.RejectedBookings</span></div>
                        <div class="col-6 mb-2"><span class="badge bg-secondary w-100">İptal: @Model.CancelledBookings</span></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-6 mb-4">
            <div class="card panel-card h-100">
                <div class="card-header bg-white border-0">
                    <h6 class="panel-title mb-0">En Yüksek Kapasiteli Destinasyonlar</h6>
                </div>
                <div class="card-body">
                    <div class="chart-wrapper" style="height:280px;">
                        <canvas id="capacityChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

                                        
        <div class="col-lg-6 mb-4">
            <div class="card panel-card h-100">
                <div class="card-header bg-white border-0">
                    <h6 class="panel-title mb-0">Finansal Özet</h6>
                </div>
                <div class="card-body">
                    <div class="d-flex flex-column gap-3">
                        <div class="p-3 rounded-3 bg-light">
                            <small class="text-muted d-block">Onaylı Rezervasyon Geliri</small>
                            <h4 class="mb-0">@Model.TotalRevenue.ToString("N0") ₺</h4>
                        </div>
                        <div class="p-3 rounded-3 bg-light">
                            <small class="text-muted d-block">Ortalama Rezervasyon Tutarı</small>
                            <h4 class="mb-0">@Model.AverageBookingAmount.ToString("N0") ₺</h4>
                        </div>
                        <div class="p-3 rounded-3 bg-light">
                            <small class="text-muted d-block">Onay Dönüşüm Oranı</small>
                            <h4 class="mb-0">%@Model.ApprovalRate.ToString("N1")</h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>


                                    </div>
    <div class="card panel-card mb-4">
        <div class="card-header bg-white border-0">
            <h6 class="panel-title mb-0">Son Eklenen Destinasyonlar</h6>
        </div>
        <div class="card-body table-responsive">
            <table class="table soft-table mb-0">
                <thead>
                    <tr>
                        <th>Görsel</th>
                        <th>Şehir / Ülke</th>
                        <th>Fiyat</th>
                        <th>Kapasite</th>
                        <th>Süre</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.LatestDestinations)
                    {
                        var img = string.IsNullOrWhiteSpace(item.ImageUrl) ? "/images/no-image.png" : item.ImageUrl;
                        <tr>
                            <td><img src="@img" class="destination-thumb" alt="@item.CityCountry" /></td>
                            <td>@item.CityCountry</td>
                            <td>@item.Price.ToString("N0") ₺</td>
                            <td>@item.Capacity kişi</td>
                            <td>@item.DayNight</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
                                       
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const statusData = @Html.Raw(Json.Serialize(Model.BookingStatusData));
        const capacities = @Html.Raw(Json.Serialize(Model.DestinationCapacities));
        const chartPixelRatio = Math.max(2, window.devicePixelRatio || 1);

        new Chart(document.getElementById('statusDistributionChart'), {
            type: 'doughnut',
            data: {
                labels: statusData.map(x => x.status),
                datasets: [{
                    data: statusData.map(x => x.count),
                    backgroundColor: ['#f59e0b', '#22c55e', '#ef4444', '#64748b'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                devicePixelRatio: chartPixelRatio,
                plugins: { legend: { position: 'bottom' } }
            }
        });

        new Chart(document.getElementById('capacityChart'), {
            type: 'bar',
            data: {
                labels: capacities.map(x => x.cityCountry),
                datasets: [{
                    label: 'Kapasite',
                    data: capacities.map(x => x.capacity),
                    backgroundColor: 'rgba(14,165,233,.75)',
                    borderRadius: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                devicePixelRatio: chartPixelRatio,
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true } }
            }
        });
    </script>
}