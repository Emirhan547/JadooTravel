@using JadooTravel.Dto.Dtos.DashboardDtos

@using System.Linq
@using Microsoft.AspNetCore.Mvc.ViewFeatures
@model DashboardStatisticsDto

@inject IJsonHelper Json

@{
    ViewData["Title"] = "AdminDashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .gradient-card {
        border: none;
        border-radius: 16px;
        color: #fff;
        overflow: hidden;
        box-shadow: 0 12px 24px rgba(15, 23, 42, .10);
    }

    .gradient-primary {
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
    }

    .gradient-success {
        background: linear-gradient(135deg, #059669, #047857);
    }

    .gradient-warning {
        background: linear-gradient(135deg, #f59e0b, #d97706);
    }

    .gradient-info {
        background: linear-gradient(135deg, #0891b2, #0e7490);
    }

    .panel-card {
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        box-shadow: 0 10px 20px rgba(15, 23, 42, .06);
    }

    .metric-badge {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        font-size: .85rem;
        padding: .45rem .75rem;
        border-radius: 999px;
        background: #f1f5f9;
        color: #0f172a;
    }

    .soft-table thead th {
        border: none;
        background: #f8fafc;
        color: #334155;
        font-weight: 600;
    }

    .soft-table td {
        border-color: #f1f5f9;
        vertical-align: middle;
    }

    .destination-thumb {
        width: 68px;
        height: 52px;
        border-radius: 10px;
        object-fit: cover;
    }
</style>

<div class="container-fluid">

    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
        <div>
            <h3 class="mb-1">Admin Dashboard</h3>
            <p class="text-muted mb-0">Genel istatistikler ve dinamik analytics görünümü</p>
        </div>

        <form method="get" asp-area="Admin" asp-controller="Dashboard" asp-action="AdminDashboard" class="d-flex align-items-end gap-2">
            <div>
                <label class="form-label mb-1">Başlangıç</label>
                <input type="date" class="form-control" name="startDate" value="@Model.StartDate.ToString("yyyy-MM-dd")" />
            </div>
            <div>
                <label class="form-label mb-1">Bitiş</label>
                <input type="date" class="form-control" name="endDate" value="@Model.EndDate.ToString("yyyy-MM-dd")" />
            </div>
            <button type="submit" class="btn btn-dark">Filtrele</button>
        </form>
    </div>

    <!-- Statistics Cards -->
    <div class="row">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card gradient-card gradient-primary">
                <div class="card-body">
                    <h6 class="text-uppercase">Toplam Kategori</h6>
                    <h2 class="mb-0">@Model.TotalCategories</h2>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card gradient-card gradient-success">
                <div class="card-body">
                    <h6 class="text-uppercase">Toplam Destinasyon</h6>
                    <h2 class="mb-0">@Model.TotalDestinations</h2>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card gradient-card gradient-warning">
                <div class="card-body">
                    <h6 class="text-uppercase">Toplam Rezervasyon</h6>
                    <h2 class="mb-0">@Model.TotalBookings</h2>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card gradient-card gradient-info">
                <div class="card-body">
                    <h6 class="text-uppercase">Toplam Yorum</h6>
                    <h2 class="mb-0">@Model.TotalTestimonials</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- KPI Row -->
    <div class="row">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card panel-card h-100">
                <div class="card-body">
                    <h6 class="text-muted">Toplam Sayfa Görüntüleme</h6>
                    <h4>@Model.TotalPageViews</h4>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card panel-card h-100">
                <div class="card-body">
                    <h6 class="text-muted">Tekil Ziyaretçi</h6>
                    <h4>@Model.UniqueVisitors</h4>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card panel-card h-100">
                <div class="card-body">
                    <h6 class="text-muted">Toplam Ciro</h6>
                    <h4>@Model.TotalRevenue.ToString("N0") ₺</h4>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card panel-card h-100">
                <div class="card-body">
                    <h6 class="text-muted">Dönüşüm Oranı</h6>
                    <h4>%@Model.ConversionRate.ToString("N2")</h4>
                </div>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-12 mb-4">
           
            <div class="card panel-card">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">En Çok Favorilenen Destinasyonlar</h6>
                    <span class="metric-badge"><i class="fa fa-heart text-danger"></i> Canlı veri</span>
                </div>

                <div class="card-body table-responsive">
                    @if (Model.FavoriteDestinationStats != null && Model.FavoriteDestinationStats.Any())
                    {
                        <table class="table soft-table mb-0">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Destinasyon</th>
                                    <th>Favori Sayısı</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (var i = 0; i < Model.FavoriteDestinationStats.Count; i++)
                                {
                                    var item = Model.FavoriteDestinationStats[i];
                                    <tr>
                                        <td>@(i + 1)</td>
                                        <td>@item.CityCountry</td>
                                        <td><span class="badge bg-danger">@item.FavoriteCount</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="alert alert-light border mb-0">Henüz favori verisi bulunmuyor.</div>
                    }
                </div>
            </div>
        </div>
    </div>
    <!-- Charts Row -->
  
    <div class="row">
        <div class="col-12 mb-4">
            <div class="card panel-card">
                <div class="card-header bg-white"><h6 class="mb-0">Son Eklenen Turlar</h6></div>

                <div class="card-body table-responsive">
                    <table class="table soft-table mb-0">
                        <thead>
                            <tr>
                                <th>Görsel</th>
                                <th>Şehir / Ülke</th>
                                <th>Fiyat</th>
                                <th>Kapasite</th>
                                <th>Süre</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.LatestDestinations.Take(5))
                            {
                                var img = string.IsNullOrWhiteSpace(item.ImageUrl) ? "/images/no-image.png" : item.ImageUrl;

                                <tr>
                                    <td>
                                        <img src="@img" class="destination-thumb" alt="@item.CityCountry" />
                                    </td>
                                    <td>@item.CityCountry</td>
                                    <td>@item.Price ₺</td>
                                    <td>@item.Capacity kişi</td>
                                    <td>@item.DayNight</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
       
        const capacities = @Html.Raw(Json.Serialize(Model.DestinationCapacities));
     
        const dailyLabels = dailyStats.map(x =>
            new Date(x.date).toLocaleDateString('tr-TR', { day: '2-digit', month: '2-digit' })
        );

        new Chart(document.getElementById('dailyTrendChart').getContext('2d'), {
            type: 'line',
            data: {
                labels: dailyLabels,
                datasets: [
                    {
                        label: 'Sayfa Görüntüleme',
                        data: dailyStats.map(x => x.pageViews),
                        borderColor: '#2563eb',
                        backgroundColor: 'rgba(37,99,235,0.2)',
                        yAxisID: 'y',
                        tension: 0.35,
                        fill: true
                    },
                    {
                        label: 'Rezervasyon',
                        data: dailyStats.map(x => x.bookings),
                        borderColor: '#10b981',
                        backgroundColor: 'rgba(16,185,129,0.1)',
                        yAxisID: 'y1',
                        tension: 0.35
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: { mode: 'index', intersect: false },
                scales: {
                    y: { beginAtZero: true, position: 'left' },
                    y1: { beginAtZero: true, position: 'right', grid: { drawOnChartArea: false } }
                }
            }
        });

        new Chart(document.getElementById('trafficSourceChart').getContext('2d'), {
            type: 'doughnut',
            data: {
                labels: trafficSources.map(x => x.source),
                datasets: [{
                    data: trafficSources.map(x => x.visits),
                    backgroundColor: ['#2563eb', '#f59e0b', '#10b981', '#8b5cf6', '#ef4444']
                }]
            },
            options: { responsive: true, maintainAspectRatio: false }
        });

        new Chart(document.getElementById('capacityChart').getContext('2d'), {
            type: 'bar',
            data: {
                labels: capacities.map(x => x.cityCountry),
                datasets: [{
                    label: 'Kapasite',
                    data: capacities.map(x => x.capacity),
                    backgroundColor: 'rgba(14,165,233,.65)',
                    borderRadius: 8
                }]
            },
            options: { responsive: true, maintainAspectRatio: false }
        });

        new Chart(document.getElementById('destinationBookingChart').getContext('2d'), {
            type: 'bar',
            data: {
                labels: destinationAnalytics.map(x => x.cityCountry),
                datasets: [{
                    label: 'Rezervasyon',
                    data: destinationAnalytics.map(x => x.bookings),
                    backgroundColor: 'rgba(99,102,241,.7)',
                    borderRadius: 8
                }]
            },
            options: { responsive: true, maintainAspectRatio: false }
        });
    </script>
}