

@using JadooTravel.Entity.Entities.Enums
@model List<ResultBookingDto>

@{
    ViewData["Title"] = "Rezervasyonlar";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int count = 0;
}

<div class="row">
    <div class="col-12">
        <div class="card card-outline card-primary">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fa fa-book mr-1"></i> Rezervasyon Listesi
                </h3>

                <div class="card-tools">
                    <div class="btn-group btn-group-sm">
                        <a href="/Admin/Booking/BookingList" class="btn btn-default active">
                            <i class="fa fa-list"></i> Tümü
                        </a>
                        <a href="/Admin/Booking/PendingBookings" class="btn btn-default">
                            <i class="fa fa-clock"></i> Beklemede
                        </a>
                    </div>
                </div>
            </div>

            <!-- Statistics Cards -->
            <div class="row p-3">
                <div class="col-md-3">
                    <div class="small-box bg-info">
                        <div class="inner">
                            <h3>@Model.Count(x => x.Status == BookingStatus.Pending)</h3>
                            <p>Beklemede</p>
                        </div>
                        
                        <div class="icon"><i class="fa fa-clock"></i></div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="small-box bg-success">
                        <div class="inner">
                            <h3>@Model.Count(x => x.Status == BookingStatus.Approved)</h3>
                            <p>Onaylandı</p>
                        </div>
                        
                        <div class="icon"><i class="fa fa-check"></i></div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="small-box bg-warning">
                        <div class="inner">
                            <h3>@Model.Count(x => x.Status == BookingStatus.Rejected)</h3>
                            <p>Reddedildi</p>
                        </div>
                      
                        <div class="icon"><i class="fa fa-times"></i></div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="small-box bg-danger">
                        <div class="inner">
                            <h3>@Model.Count(x => x.Status == BookingStatus.Cancelled)</h3>
                          
                            <p>Pasif / İptal</p>
                        </div>
                        <div class="icon"><i class="fa fa-ban"></i></div>
                    </div>
                </div>
            </div>

            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover mb-0">
                        <thead class="thead-light">
                            <tr>
                                <th style="width:30px">#</th>
                                <th>İsim</th>
                                <th>Email</th>
                                <th>Telefon</th>
                                <th>Tarih</th>
                                <th>Kişi Sayısı</th>
                                <th>Toplam Fiyat</th>
                                <th style="width:120px">Durumu</th>
                            
                                <th style="width:300px">İşlemler</th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (Model != null && Model.Count > 0)
                            {
                                foreach (var item in Model)
                                {
                                    count++;
                                    <tr>
                                        <td>@count</td>
                                        
                                        <td><strong>@item.FullName</strong></td>
                                        <td><a href="mailto:@item.Email">@item.Email</a></td>
                                        <td><a href="tel:@item.Phone">@item.Phone</a></td>
                                        <td>@item.CreatedDate.ToString("dd.MM.yyyy HH:mm")</td>
                                        <td><span class="badge badge-primary">@item.PersonCount</span></td>
                                        <td><strong>@item.TotalPrice.ToString("C")</strong></td>
                                        <td>
                                            @if (item.Status == BookingStatus.Pending)
                                            {
                                                <span class="badge badge-warning">Beklemede</span>
                                            }
                                            else if (item.Status == BookingStatus.Approved)
                                            {
                                                <span class="badge badge-success">Onaylandı</span>
                                            }
                                            else if (item.Status == BookingStatus.Rejected)
                                            {
                                                <span class="badge badge-danger">Reddedildi</span>
                                            }
                                       
                                                                        else
                                    {
                                 
                                    <span class="badge badge-secondary">Pasif / İptal</span>
                                    }
                                </td>
                               
                                <td class="d-flex flex-wrap gap-1">
                                    <a href="/Admin/Booking/BookingDetails/@item.Id" class="btn btn-info btn-sm">
                                        <i class="fa fa-eye"></i> Gör
                                    </a>

                                    @if (item.Status == BookingStatus.Pending)
                                                    {
                                                        
                                                        <form method="post" asp-action="ApproveBooking" asp-controller="Booking" asp-area="Admin" class="d-inline">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="id" value="@item.Id" />
                                                            <button type="submit" class="btn btn-success btn-sm">
                                                                <i class="fa fa-check"></i> Onayla
                                                            </button>
                                                        </form>

                                                        <form method="post" asp-action="RejectBooking" asp-controller="Booking" asp-area="Admin" class="d-inline">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="id" value="@item.Id" />
                                                            <input type="hidden" name="notes" value="Rezervasyon admin tarafından reddedildi." />
                                                            <button type="submit" class="btn btn-warning btn-sm">
                                                                <i class="fa fa-times"></i> Reddet
                                                            </button>
                                                        </form>
                                                    }

                                           
                                            @if (item.Status != BookingStatus.Cancelled)
                                            {
                                                <form method="post" asp-action="SetPassive" asp-controller="Booking" asp-area="Admin" class="d-inline"
                                                      onsubmit="return confirm('Bu rezervasyonu pasife çekmek istediğinize emin misiniz?');">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@item.Id" />
                                                    <input type="hidden" name="notes" value="Rezervasyon admin tarafından pasife çekildi." />
                                                    <button type="submit" class="btn btn-secondary btn-sm">
                                                        <i class="fa fa-ban"></i> Pasife Çek
                                                    </button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    
                                    <td colspan="9" class="text-center text-muted p-4">Kayıtlı rezervasyon bulunamadı.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

