@using JadooTravel.Dto.Dtos.PartnerDtos
@model CreatePartnerDto
@{
    ViewData["Title"] = "Yeni Partner"; Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="card">
    <div class="card-header"><h3 class="card-title">Yeni Partner Oluştur</h3></div><form method="post" enctype="multipart/form-data">
        <div class="card-body">
            <div class="form-group"><label>Partner Adı</label><input asp-for="Name" class="form-control" /></div>

            <div class="form-group"><label>S3 Görsel Yükle</label><input type="file" name="imageFile" accept="image/*" class="form-control" /></div>
            <div class="form-group"><label>Sıra</label><input asp-for="Order" type="number" class="form-control" /></div>
        </div><div class="card-footer"><button class="btn btn-success">Kaydet</button><a href="/Admin/Partner/PartnerList" class="btn btn-secondary ml-2">İptal</a></div>
    </form>
</div>