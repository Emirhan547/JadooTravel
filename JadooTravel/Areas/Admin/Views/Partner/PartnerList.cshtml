@using JadooTravel.Dto.Dtos.PartnerDtos
@model List<ResultPartnerDto>
@{
    ViewData["Title"] = "Partner Alanı"; Layout = "~/Views/Shared/_AdminLayout.cshtml"; int count = 0;
}
<div class="row">
    <div class="col-12">
        <div class="card card-outline card-primary">
            <div class="card-header"><h3 class="card-title"><i class="fa fa-handshake-o mr-1"></i> Partner Listesi</h3><div class="card-tools"><a href="/Admin/Partner/CreatePartner" class="btn btn-info btn-sm"><i class="fa fa-plus"></i> Yeni Partner</a></div></div><div class="card-body p-0">
                <table class="table table-bordered table-hover mb-0">
                    <thead><tr><th>#</th><th>Ad</th><th>Görsel</th><th>Sıra</th><th>İşlemler</th></tr></thead>
                    <tbody>
                        @if (Model != null && Model.Count > 0)
                        {
                            foreach (var item in Model)
                            {
                                count++;
                                <tr><td>@count</td><td>@item.Name</td><td><a href="@item.ImageUrl" target="_blank">Görsel</a></td><td>@item.Order</td><td><a href="/Admin/Partner/UpdatePartner/@item.Id" class="btn btn-success btn-sm"><i class="fa fa-edit"></i></a> <a href="/Admin/Partner/DeletePartner/@item.Id" class="btn btn-danger btn-sm" onclick="return confirm('Silinsin mi?')"><i class="fa fa-trash"></i></a></td></tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="5" class="text-center text-muted p-4">Kayıt bulunamadı.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>